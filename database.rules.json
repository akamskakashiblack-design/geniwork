{
  "rules": {
    "gw": {

      /* ── Utilisateurs ── */
      "users": {
        ".read":  true,
        ".write": "auth != null"
      },

      /* ── Profils ── */
      "profiles": {
        ".read":  true,
        "$userFbKey": {
          ".write": "auth != null"
        }
      },

      /* ── DM : liste des conversations (métadonnées) ── */
      "dms": {
        "$userFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      /* ── DM : messages ── */
      "dm_msgs": {
        "$dmFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null",
          "$msgId": {
            ".validate": "newData.hasChildren(['id','from','at']) && (newData.hasChild('text') || (newData.hasChild('type') && (newData.child('type').val() === 'img' || newData.child('type').val() === 'video' || newData.child('type').val() === 'file')))"
          }
        }
      },

      /* ── DM : métadonnées de conversation ── */
      "dm_meta": {
        "$dmFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      /* ── Boîte de réception DM ── */
      "inboxes": {
        "$toFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      /* ── Groupes : messages ── */
      "group_msgs": {
        "$grpFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      /* ── Groupes : boîte de réception ── */
      "group_inboxes": {
        "$userFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      /* ── Publications (feed) ── */
      "posts": {
        ".read":  true,
        "$userFbKey": {
          ".write": "auth != null"
        }
      },
      "post_imgs": {
        ".read":  true,
        "$postId": {
          ".write": "auth != null"
        }
      },
      "post_videos": {
        ".read":  true,
        "$postId": {
          ".write": "auth != null"
        }
      },
      "official_posts": {
        ".read":  true,
        ".write": "auth != null"
      },

      /* ── Interactions ── */
      "likes": {
        ".read":  true,
        "$postId": {
          ".write": "auth != null"
        }
      },
      "dislikes": {
        ".read":  true,
        "$postId": {
          ".write": "auth != null"
        }
      },
      "comments": {
        ".read":  true,
        "$postId": {
          ".write": "auth != null"
        }
      },
      "rcounts": {
        ".read":  true,
        "$postId": {
          ".write": "auth != null"
        }
      },
      "creact": {
        ".read":  true,
        "$cid": {
          ".write": "auth != null"
        }
      },

      /* ── Vues vidéo ── */
      "vid_views": {
        ".read":  true,
        "$postId": {
          ".write": "auth != null"
        }
      },
      "viewed_vids": {
        "$userFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      /* ── Abonnements (follow) ── */
      "following": {
        ".read":  true,
        "$userFbKey": {
          ".write": "auth != null"
        }
      },
      "follow_counts": {
        ".read":  true,
        "$profileFbKey": {
          ".write": "auth != null"
        }
      },
      "followers": {
        "$profileFbKey": {
          ".read":  true,
          ".write": "auth != null"
        }
      },

      /* ── Notifications ── */
      "notifs": {
        "$userFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },
      "fcm_tokens": {
        "$userFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      /* ── Marketplace ── */
      "mk_listings": {
        ".read":  true,
        ".write": "auth != null"
      },
      "mk_txns": {
        ".read":  "auth != null",
        ".write": "auth != null"
      },

      /* ── Collaboration ── */
      "collab_requests": {
        ".read":  true,
        ".write": "auth != null"
      },
      "collab_invites": {
        "$userFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },
      "milestones": {
        "$userFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      /* ── Services & Projets ── */
      "services": {
        ".read":  true,
        "$userFbKey": {
          ".write": "auth != null"
        }
      },
      "projects": {
        ".read":  true,
        "$userFbKey": {
          ".write": "auth != null"
        }
      },

      /* ── Avis ── */
      "reviews": {
        ".read":  true,
        "$profileFbKey": {
          ".write": "auth != null"
        }
      },

      /* ── Modération ── */
      "bans": {
        ".read":  "auth != null",
        ".write": "auth != null"
      },
      "reports": {
        "$userFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },
      "blocked": {
        "$userFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      /* ── Confidentialité ── */
      "privacy": {
        "$userFbKey": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      /* ── Administration ── */
      "admin_tasks": {
        ".read":  "auth != null",
        ".write": "auth != null"
      },
      "badge_requests": {
        ".read":  "auth != null",
        ".write": "auth != null"
      },
      "publishers": {
        ".read":  "auth != null",
        ".write": "auth != null"
      },
      "settings_logo": {
        ".read":  true,
        ".write": "auth != null"
      }

    }
  }
}
